&CONTROL
  calculation = 'nscf'
  restart_mode = 'from_scratch'
  outdir = './'
  pseudo_dir = './'
  verbosity = 'high'
  wf_collect = .true.
  prefix = 'hBN_bulk'
/
&SYSTEM
  ibrav = 0
  nat = 4
  ntyp = 2
  occupations = 'fixed'
  ecutwfc = 80.0
  ecutrho = 320.0
  nbnd = 160
/
&ELECTRONS
  conv_thr = 1.0d-8
  mixing_beta = 0.3
  electron_maxstep = 250
  diagonalization = 'david'
/
ATOMIC_SPECIES
B 10.810 B_ONCV_PBE-1.0.upf
N 14.007 N_ONCV_PBE-1.0.upf
CELL_PARAMETERS angstrom
   2.5040000000   0.0000000000   0.0000000000
  -1.2520000000   2.1685000000   0.0000000000
   0.0000000000   0.0000000000   6.6600000000
ATOMIC_POSITIONS crystal
B   0.0000000000   0.0000000000   0.2500000000
N   0.3333333333   0.6666666667   0.2500000000
B   0.0000000000   0.0000000000   0.7500000000
N   0.6666666667   0.3333333333   0.7500000000
K_POINTS automatic
10 10 4  0 0 0
