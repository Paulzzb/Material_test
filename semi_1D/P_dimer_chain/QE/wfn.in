&CONTROL
  calculation = 'nscf'
  restart_mode = 'from_scratch'
  outdir = './'
  pseudo_dir = './'
  verbosity = 'high'
  wf_collect = .true.
  prefix = 'P_dimer_chain'
/
&SYSTEM
  ibrav = 0
  nat = 4
  ntyp = 1
  occupations = 'fixed'
