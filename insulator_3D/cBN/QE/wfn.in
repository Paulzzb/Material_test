&CONTROL
  calculation = 'nscf'
  restart_mode = 'from_scratch'
  outdir = './'
  pseudo_dir = './'
  verbosity = 'high'
  wf_collect = .true.
  prefix = 'cBN'
/
&SYSTEM
  ibrav = 0
  nat = 2
  ntyp = 2
  occupations = 'fixed'
  ecutwfc = 80.0
  ecutrho = 320.0
  nbnd = 120
/
&ELECTRONS
  conv_thr = 1.0d-8
  mixing_beta = 0.3
  electron_maxstep = 250
  diagonalization = 'david'
/
ATOMIC_SPECIES
B 10.810 B_ONCV_PBE-1.0.upf
N 14.007 N_ONCV_PBE-1.0.upf
CELL_PARAMETERS angstrom
   0.0000000000   1.7850000000   1.7850000000
   1.7850000000   0.0000000000   1.7850000000
   1.7850000000   1.7850000000   0.0000000000
ATOMIC_POSITIONS crystal
B   0.0000000000   0.0000000000   0.0000000000
N   0.2500000000   0.2500000000   0.2500000000
K_POINTS automatic
8 8 8  0 0 0
