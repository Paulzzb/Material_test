&CONTROL
  calculation = 'nscf'
  restart_mode = 'from_scratch'
  outdir = './'
  pseudo_dir = './'
  verbosity = 'high'
  wf_collect = .true.
  prefix = 'B2N2_cluster'
/
&SYSTEM
  ibrav = 0
  nat = 4
  ntyp = 2
  occupations = 'fixed'
  ecutwfc = 70.0
  ecutrho = 280.0
  nbnd = 40
/
&ELECTRONS
  conv_thr = 1.0d-8
  mixing_beta = 0.3
  electron_maxstep = 250
  diagonalization = 'david'
/
ATOMIC_SPECIES
B 10.810 B_ONCV_PBE-1.0.upf
N 14.007 N_ONCV_PBE-1.0.upf
CELL_PARAMETERS angstrom
   16.0000000000   0.0000000000   0.0000000000
   0.0000000000   16.0000000000   0.0000000000
   0.0000000000   0.0000000000   16.0000000000
ATOMIC_POSITIONS crystal
B   0.4500000000   0.5000000000   0.5000000000
N   0.5000000000   0.5500000000   0.5000000000
B   0.5500000000   0.5000000000   0.5000000000
N   0.5000000000   0.4500000000   0.5000000000
K_POINTS automatic
1 1 1  0 0 0
