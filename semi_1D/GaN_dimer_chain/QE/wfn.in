&CONTROL
  calculation = 'nscf'
  restart_mode = 'from_scratch'
  outdir = './'
  pseudo_dir = './'
  verbosity = 'high'
  wf_collect = .true.
  prefix = 'GaN_dimer_chain'
/
&SYSTEM
  ibrav = 0
  nat = 4
  ntyp = 2
  occupations = 'fixed'
  ecutwfc = 60.0
  ecutrho = 240.0
  nbnd = 60
/
&ELECTRONS
  conv_thr = 1.0d-8
  mixing_beta = 0.3
  electron_maxstep = 250
  diagonalization = 'david'
/
ATOMIC_SPECIES
Ga 69.723 Ga_ONCV_PBE-1.0.upf
N 14.007 N_ONCV_PBE-1.0.upf
CELL_PARAMETERS angstrom
   14.0000000000   0.0000000000   0.0000000000
   0.0000000000   14.0000000000   0.0000000000
   0.0000000000   0.0000000000   9.2000000000
ATOMIC_POSITIONS crystal
Ga   0.5000000000   0.5000000000   0.1000000000
N   0.5000000000   0.5000000000   0.3000000000
Ga   0.5000000000   0.5000000000   0.6000000000
N   0.5000000000   0.5000000000   0.8000000000
K_POINTS automatic
1 1 8  0 0 0
