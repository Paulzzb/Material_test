&CONTROL
  calculation = 'nscf'
  restart_mode = 'from_scratch'
  prefix = 'AlAs_molecule'
  outdir = './'
  pseudo_dir = './'
  verbosity = 'high'
/
&SYSTEM
  ibrav = 0
  nat = 2
  ntyp = 2
  occupations = 'fixed'
  ecutwfc = 70.0
  ecutrho = 280.0
  nbnd = 24
/
&ELECTRONS
  conv_thr = 1.0d-8
  mixing_beta = 0.3
  electron_maxstep = 200
/
ATOMIC_SPECIES
Al 26.982 Al_ONCV_PBE-1.0.upf
As 74.922 As_ONCV_PBE-1.0.upf
CELL_PARAMETERS angstrom
   16.0000000000   0.0000000000   0.0000000000
   0.0000000000   16.0000000000   0.0000000000
   0.0000000000   0.0000000000   16.0000000000
ATOMIC_POSITIONS crystal
Al   0.5000000000   0.5000000000   0.4700000000
As   0.5000000000   0.5000000000   0.5300000000
K_POINTS automatic
1 1 1  0 0 0
